{{!
  space.hbs — A dark, futuristic theme with an animated starfield.
  Renders from profile.json
}}
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{displayName}} — {{title}}</title>
  <meta name="description" content="{{headline}}" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Overpass+Mono:wght@700&family=Titillium+Web:wght@400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #000000;
      --ink: #e0e0e0;
      --primary: #00ffff; /* cyan */
      --secondary: #ff7f50; /* coral */
      --border: rgba(0, 255, 255, 0.2);
      --card-bg: rgba(20, 20, 30, 0.5);
      --white: #ffffff;
      --display: "Overpass Mono", monospace;
      --sans: "Titillium Web", sans-serif;
    }

    @keyframes move-stars {
      from { transform: translateY(0); }
      to { transform: translateY(-2000px); }
    }

    @keyframes comet-animation {
      0% {
        transform: translate(-50vw, -50vh) rotate(45deg);
        opacity: 0;
      }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% {
        transform: translate(50vw, 50vh) rotate(45deg);
        opacity: 0;
      }
    }

    @keyframes twinkle {
      0%, 100% {
        opacity: 0.3;
      }
      50% {
        opacity: 1;
      }
    }

    html {
      scroll-behavior: smooth;
      scroll-padding-top: 100px;
    }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--sans);
      margin: 0;
      line-height: 1.6;
      overflow-x: hidden;
    }

    body::after {
      content: '';
      position: fixed;
      top: -50%;
      left: 50%;
      width: 3px;
      height: 200%;
      background: rgba(255, 255, 255, 0.08);
      transform: rotate(45deg);
      z-index: -2;
    }

    .comet {
      position: fixed;
      top: 50%;
      left: 50%;
      width: 250px;
      height: 2px;
      background: linear-gradient(to left, var(--white), transparent);
      border-radius: 50%;
      animation: comet-animation 15s linear infinite;
      z-index: -1;
    }

    .starfield {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 2000px; /* Taller than viewport for seamless animation */
      z-index: -1;
    }

    .stars {
      width: 3px;
      height: 3px;
      background: transparent;
      animation: move-stars 50s linear infinite;
    }
    .stars.s1 {
      animation-duration: 50s;
      box-shadow: 597px 1502px #FFF, 173px 1077px #FF7F50, 1292px 1205px #00FFFF, 1803px 138px #FFF, 1269px 1163px #FFF, 145px 1204px #FFF, 1032px 1123px #00FFFF, 1932px 1666px #FFF, 1289px 1271px #FFF, 1003px 1904px #FF7F50, 100px 100px #FFF, 1200px 500px #00FFFF, 800px 1800px #FF7F50, 1500px 1000px #FFF, 432px 888px #FFF, 876px 345px #FF7F50, 1500px 1800px #00FFFF;
    }
    .stars.s2 {
      animation-duration: 100s;
      box-shadow: 1879px 113px #FFF, 1013px 105px #FFF, 1080px 1450px #00FFFF, 1191px 1383px #FFF, 1331px 1228px #FF7F50, 194px 1469px #FFF, 1335px 1142px #FFF, 1285px 1299px #00FFFF, 1439px 138px #FFF, 1019px 1399px #FFF, 1833px 128px #FF7F50, 1500px 800px #FFF, 400px 1200px #00FFFF, 1800px 1600px #FF7F50, 222px 666px #FFF, 777px 999px #00FFFF;
    }
    .stars.s3 {
      animation-duration: 150s;
      box-shadow: 1748px 1280px #FFF, 184px 133px #FF7F50, 1599px 1297px #FFF, 1499px 1193px #FFF, 184px 1038px #00FFFF, 1291px 113px #FFF, 125px 1268px #FFF, 110px 1252px #FFF, 1178px 1395px #00FFFF, 1491px 100px #FF7F50, 600px 1500px #FFF, 1000px 1000px #00FFFF, 333px 777px #FF7F50, 1400px 200px #FFF;
    }

    .static-stars, .twinkling-stars-1, .twinkling-stars-2 {
      position: absolute;
      top: 0;
      left: 0;
      width: 2px;
      height: 2px;
      background: transparent;
    }
    .twinkling-stars-1, .twinkling-stars-2 {
      animation: twinkle 7s ease-in-out infinite;
    }
    .twinkling-stars-2 {
      animation-duration: 9s;
      animation-delay: -3s;
    }

    .static-stars {
      box-shadow: 1886px 1775px #FFF, 1999px 1620px #FF7F50, 1578px 1136px #00FFFF, 1190px 1935px #FFF, 1188px 1853px #FFF, 1930px 114px #FFF, 101px 1628px #00FFFF, 110px 1252px #FFF, 1178px 1395px #00FFFF, 1491px 100px #FF7F50, 600px 1500px #FFF, 1000px 1000px #00FFFF, 800px 800px #FF7F50, 1300px 1300px #FFF, 1748px 1280px #FFF, 184px 133px #FF7F50, 1599px 1297px #FFF, 1499px 1193px #FFF, 184px 1038px #00FFFF, 1291px 113px #FFF, 125px 1268px #FFF, 110px 1252px #FFF, 1178px 1395px #00FFFF, 1491px 100px #FF7F50, 600px 1500px #FFF, 1000px 1000px #00FFFF, 800px 800px #FF7F50, 1300px 1300px #FFF, 597px 1502px #FFF, 173px 1077px #FF7F50, 1292px 1205px #00FFFF, 1803px 138px #FFF, 1269px 1163px #FFF, 145px 1204px #FFF, 1032px 1123px #00FFFF, 1932px 1666px #FFF, 1289px 1271px #FFF, 1003px 1904px #FF7F50, 100px 100px #FFF, 1200px 500px #00FFFF, 800px 1800px #FF7F50, 1500px 1000px #FFF, 1886px 775px #FFF, 1999px 620px #FF7F50, 1578px 136px #00FFFF, 1190px 935px #FFF, 1188px 853px #FFF, 1930px 1114px #FFF, 101px 628px #00FFFF, 110px 252px #FFF, 1178px 395px #00FFFF, 1491px 1100px #FF7F50, 600px 500px #FFF, 1000px 100px #00FFFF, 800px 1800px #FF7F50, 1300px 300px #FFF;
    }
    .twinkling-stars-1 {
      box-shadow: 1819px 1013px #FFF, 1080px 1450px #00FFFF, 1191px 1383px #FFF, 1331px 1228px #FF7F50, 194px 1469px #FFF, 1335px 1142px #FFF, 1285px 1299px #00FFFF, 1439px 138px #FFF, 1019px 1399px #FFF, 1833px 128px #FF7F50, 1500px 800px #FFF, 400px 1200px #00FFFF, 1800px 1600px #FF7F50, 1879px 113px #FFF, 1013px 105px #FFF, 1080px 1450px #00FFFF, 1191px 1383px #FFF, 1331px 1228px #FF7F50, 194px 1469px #FFF, 1335px 1142px #FFF, 1285px 1299px #00FFFF, 1439px 138px #FFF, 1019px 1399px #FFF, 1833px 128px #FF7F50, 1500px 800px #FFF, 400px 1200px #00FFFF, 1800px 1600px #FF7F50, 819px 13px #FFF, 100px 450px #00FFFF, 191px 383px #FFF, 331px 228px #FF7F50;
    }
    .twinkling-stars-2 {
      box-shadow: 1886px 1775px #FFF, 1999px 1620px #FF7F50, 1578px 1136px #00FFFF, 1190px 1935px #FFF, 1188px 1853px #FFF, 1930px 114px #FFF, 101px 1628px #00FFFF, 110px 1252px #FFF, 1178px 1395px #00FFFF, 1491px 100px #FF7F50, 600px 1500px #FFF, 1000px 1000px #00FFFF, 800px 800px #FF7F50, 1300px 1300px #FFF, 1748px 1280px #FFF, 184px 133px #FF7F50, 1599px 1297px #FFF, 1499px 1193px #FFF, 184px 1038px #00FFFF, 1291px 113px #FFF, 125px 1268px #FFF, 110px 1252px #FFF, 1178px 1395px #00FFFF, 1491px 100px #FF7F50, 600px 1500px #FFF, 1000px 1000px #00FFFF, 800px 800px #FF7F50, 1300px 1300px #FFF, 886px 775px #FFF, 999px 620px #FF7F50, 578px 136px #00FFFF, 190px 935px #FFF;
    }

    .wrap {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 2rem;
    }
    section {
      padding: 4rem 0;
    }
    section:not(.hero) {
      border-top: 1px solid var(--border);
      margin-top: 2rem;
    }
    .sec-title {
      font-size: 2.2rem;
      margin-top: 2rem;
      margin-bottom: 2.5rem;
      text-align: center;
      color: var(--primary);
    }
    h1, h2, h3, h4, .brand {
      font-family: var(--display);
      font-weight: 700;
    }

    /* Header */
    header.site {
      padding: 1.5rem 0;
      position: sticky;
      top: 0;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(10px);
      z-index: 10;
      border-bottom: 1px solid var(--border);
    }
    .nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .brand {
      font-size: 1.5rem;
      text-decoration: none;
      color: var(--primary-light);
    }
    .nav-links {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      gap: 1.5rem;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--primary-light);
      font-weight: 600;
      transition: color 0.2s;
    }
    .nav-links a:hover {
      color: var(--primary);
    }

    /* Hero */
    .hero {
      padding: 5rem 0;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      border-top: none;
    }
    .hero-photo {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--primary);
      box-shadow: 0 0 20px rgba(0, 255, 255, 0.5);
      margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-size: 3rem;
      margin: 0 0 0.5rem;
      color: var(--white);
    }
    .hero .headline {
      font-size: 1.25rem;
      color: var(--primary);
      margin-bottom: 1.5rem;
    }
    .hero-contact {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .hero-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 0;
      justify-content: center;
      align-items: center;
    }
    .hero-links a {
      color: var(--secondary);
      font-weight: 600;
      text-decoration: none;
    }
    .hero-links a + a::before {
      content: '|';
      display: inline-block;
      padding: 0 1.5rem;
      opacity: 0.5;
    }
    .location {
      margin-top: 1.5rem;
      opacity: 0.8;
    }
    .btn {
      display: inline-block;
      background: var(--primary);
      color: var(--bg);
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      transition: background 0.2s;
      box-shadow: 0 0 15px rgba(255, 255, 255, 0.4);
    }
    .btn:hover {
      background: var(--white);
    }

    /* Grids & Cards */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      backdrop-filter: blur(5px);
      transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 0 15px var(--border);
    }
    .card h3 {
      color: var(--primary);
    }
    .card h4 {
      color: var(--primary);
    }
    .card .co {
      font-size: 0.9rem;
      margin-bottom: 1rem;
      color: var(--secondary);
    }
    .card .tagline {
      font-style: italic;
      opacity: 0.8;
      margin-bottom: 1rem;
    }
    .card .highlights {
      margin: 1rem 0;
      padding-left: 1.2rem;
      font-size: 0.9rem;
      opacity: 0.9;
    }
    .card .tech-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 1.5rem 0;
    }
    .card .tech-item {
      background: var(--border);
      color: var(--primary);
      padding: 0.25rem 0.75rem;
      border-radius: 1rem;
      font-size: 0.8rem;
      font-weight: 600;
    }
    .card .project-links {
      margin-top: auto;
      padding-top: 1rem;
      display: flex;
      gap: 1rem;
    }
    .card .project-links a {
      color: var(--secondary);
      font-weight: 600;
      text-decoration: none;
    }

    /* Skills */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
    }
    .skill-list { list-style: none; padding: 0; margin: 0; }
    .skill-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
    }
    .skill-item:last-child { border-bottom: none; }
    .skill-level {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: capitalize;
      padding: 0.1rem 0.5rem;
      border-radius: 4px;
    }
    .skill-level.expert { background-color: rgba(0, 255, 255, 0.2); color: var(--primary); }
    .skill-level.advanced { background-color: rgba(0, 255, 255, 0.1); color: #adeeee; }
    .skill-level.intermediate { background-color: rgba(255, 127, 80, 0.2); color: var(--secondary); }
    .skill-level.beginner { background-color: rgba(255, 127, 80, 0.1); color: #f9b599; }

    /* Testimonials */
    .testimonial-card { display: flex; flex-direction: column; }
    .quote {
      font-size: 1.1rem;
      font-style: italic;
      margin: 0 0 1.5rem;
      border-left: 3px solid var(--primary);
      padding-left: 1rem;
      flex-grow: 1;
    }
    .author { font-weight: 600; align-self: flex-end; text-align: right; }

    /* List Sections */
    .list-section { display: flex; flex-direction: column; gap: 1rem; }
    .list-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .list-item .meta {
      margin: 0;
      font-size: 0.9rem;
      opacity: 0.8;
      flex-shrink: 0;
    }
    .list-item .links a {
      color: var(--secondary);
      font-weight: 600;
      text-decoration: none;
      margin-left: 1rem;
    }
    .list-item h4 a {
      color: var(--primary);
      text-decoration: none;
      transition: color 0.2s;
    }
    .list-item h4 a:hover {
      color: var(--white);
    }
    .interests-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: center;
    }
    .interest-item {
      background: var(--border);
      color: var(--primary);
      padding: 0.5rem 1rem;
      border-radius: 1.5rem;
      font-weight: 600;
    }

    /* Footer */
    footer.site {
      text-align: center;
      padding: 2rem 0;
      margin-top: 3rem;
      border-top: 1px solid var(--border);
      color: var(--ink);
      opacity: 0.8;
    }
    footer.site a {
      color: var(--primary);
      font-weight: 600;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="comet"></div>
  <div class="starfield">
    <div class="stars s1"></div>
    <div class="stars s2"></div>
    <div class="stars s3"></div>
    <div class="static-stars"></div>
    <div class="twinkling-stars-1"></div>
    <div class="twinkling-stars-2"></div>
  </div>

  <header class="site">
    <div class="wrap nav">
      <a href="#" class="brand">{{displayName}}</a>
      <ul class="nav-links">
        {{#has experience}}<li><a href="#experience">Experience</a></li>{{/has}}
        {{#has projects}}<li><a href="#projects">Projects</a></li>{{/has}}
        {{#has skills}}<li><a href="#skills">Skills</a></li>{{/has}}
        {{#has testimonials}}<li><a href="#testimonials">More</a></li>{{/has}}
      </ul>
    </div>
  </header>

  <main>
    <section class="hero wrap">
      {{#if photo}}<img src="{{photo}}" alt="{{displayName}}" class="hero-photo">{{/if}}
      <h1>{{displayName}}</h1>
      <p class="headline">{{title}}</p>
      <p>{{bio}}</p>
      <div class="hero-contact">
        {{#if email}}<a href="mailto:{{email}}" class="btn">Get In Touch</a>{{/if}}
        <div class="hero-links">
          {{#each socialLinks}}<a href="{{url}}" target="_blank" rel="noopener">{{label}}</a>{{/each}}
          {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">{{stripProtocol website}}</a>{{/if}}
        </div>
      </div>
      {{#if locationStr}}<p class="location">{{locationStr}}</p>{{/if}}
    </section>

    {{#has experience}}
    <section class="wrap">
      <h2 id="experience" class="sec-title">Work Experience</h2>
      <div class="grid">
        {{#each experience}}
        <div class="card">
          <h3>{{role}}</h3>
          <p class="co">{{company}} | {{fmtDate startDate}} - {{fmtDate endDate}}</p>
          <p>{{description}}</p>
          {{#has highlights}}
          <ul class="highlights">
            {{#each highlights}}<li>{{.}}</li>{{/each}}
          </ul>
          {{/has}}
        </div>
        {{/each}}
      </div>
    </section>
    {{/has}}

    {{#has projects}}
    <section class="wrap">
      <h2 id="projects" class="sec-title">Featured Projects</h2>
      <div class="grid">
        {{#each projects}}
        <div class="card" style="display: flex; flex-direction: column;">
          <h3>{{name}}</h3>
          {{#if tagline}}<p class="tagline">{{tagline}}</p>{{/if}}
          <p>{{description}}</p>
          {{#has highlights}}<ul class="highlights">{{#each highlights}}<li>{{.}}</li>{{/each}}</ul>{{/has}}
          {{#has techStack}}<div class="tech-stack">{{#each techStack}}<span class="tech-item">{{.}}</span>{{/each}}</div>{{/has}}
          <div class="project-links">
            {{#if liveUrl}}<a href="{{liveUrl}}" target="_blank" rel="noopener">Live Demo</a>{{/if}}
            {{#if repoUrl}}<a href="{{repoUrl}}" target="_blank" rel="noopener">View Source</a>{{/if}}
          </div>
        </div>
        {{/each}}
      </div>
    </section>
    {{/has}}

    {{#has skills}}
    <section class="wrap">
      <h2 id="skills" class="sec-title">Skills</h2>
      <div class="skills-grid">
        {{#each skills}}
        <div class="card">
          <h3>{{category}}</h3>
          <ul class="skill-list">
            {{#each items}}
            <li class="skill-item">
              <span>{{name}}</span>
              <span class="skill-level {{lowercase level}}">{{level}}</span>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/each}}
      </div>
    </section>
    {{/has}}

    <div id="more">
      {{#has testimonials}}
      <section class="wrap">
        <h2 id="testimonials" class="sec-title">Testimonials</h2>
        <div class="grid">
          {{#each testimonials}}
          <div class="card testimonial-card">
            <blockquote class="quote">"{{quote}}"</blockquote>
            <cite class="author">{{author}}{{#if role}}, {{role}}{{/if}}{{#if company}} at {{company}}{{/if}}</cite>
          </div>
          {{/each}}
        </div>
      </section>
      {{/has}}

      {{#has talks}}
      <section class="wrap list-section">
        <h2 id="talks" class="sec-title">Talks</h2>
        {{#each talks}}
        <div class="list-item card">
          <div>
            <h4>{{title}}</h4>
            <p class="meta">{{event}} &middot; {{fmtDate date}}</p>
          </div>
          <div class="links">
            {{#if slidesUrl}}<a href="{{slidesUrl}}" target="_blank" rel="noopener">Slides</a>{{/if}}
            {{#if videoUrl}}<a href="{{videoUrl}}" target="_blank" rel="noopener">Video</a>{{/if}}
          </div>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has publications}}
      <section class="wrap list-section">
        <h2 id="publications" class="sec-title">Publications</h2>
        {{#each publications}}
        <div class="list-item card">
          <h4><a href="{{url}}" target="_blank" rel="noopener">{{title}}</a></h4>
          <p class="meta">{{publisher}} &middot; {{fmtDate date}}</p>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has certifications}}
      <section class="wrap list-section">
        <h2 id="certifications" class="sec-title">Certifications</h2>
        {{#each certifications}}
        <div class="list-item card">
          <h4>{{name}}</h4>
          <p class="meta">{{issuer}} &middot; {{fmtDate date}}</p>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has awards}}
      <section class="wrap list-section">
        <h2 id="awards" class="sec-title">Awards</h2>
        {{#each awards}}
        <div class="list-item card">
          <h4>{{title}}</h4>
          <p class="meta">{{issuer}} &middot; {{date}}</p>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has education}}
      <section class="wrap list-section">
        <h2 id="education" class="sec-title">Education</h2>
        {{#each education}}
        <div class="list-item card">
          <div>
            <h4>{{degree}} in {{field}}</h4>
            <p class="meta">{{institution}} &middot; {{startDate}} - {{endDate}}</p>
          </div>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has interests}}
      <section class="wrap">
        <h2 id="interests" class="sec-title">Interests</h2>
        <div class="interests-list">
          {{#each interests}}<span class="interest-item">{{.}}</span>{{/each}}
        </div>
      </section>
      {{/has}}
    </div>
  </main>

  <footer class="site">
    <div class="wrap">
      <p>&copy; {{year}} {{displayName}}. All rights reserved. | Built with <a href="{{toolsUrl}}">One File Tools</a></p>
    </div>
  </footer>
</body>
</html>