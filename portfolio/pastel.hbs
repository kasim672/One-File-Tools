<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{displayName}} — Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cause&family=Overpass+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <style>
      /* === Reset === */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      @keyframes gradient-animation {
        0% { background-position: 0% 0%; }
        25% { background-position: 100% 0%; }
        50% { background-position: 100% 100%; }
        75% { background-position: 0% 100%; }
        100% { background-position: 0% 0%; }
      }

      /* === Base === */
      body {
        font-family: "Cause", cursive;
        font-size: 16px;
        line-height: 1.6;
        background: linear-gradient(-45deg, #d4edda, #d1e7ff, #ffd1dc, #e6e6fa);
        background-size: 400% 400%;
        animation: gradient-animation 15s ease infinite;
        background-attachment: fixed;
      }

      .page-wrapper {
        display: flex;
        min-height: 100vh;
      }

      a {
        color: #9b59b6;
        text-decoration: none;
        font-weight: bold;
      }
      a:hover {
        text-decoration: underline;
      }

      .source-code-link {
        color: rgb(125, 125, 255);
      }

      .sidebar {
        flex: 0 0 30%;
        background-color: transparent;
        padding: 2rem 0 2rem 2rem;
        display: flex;
        flex-direction: column;
        border-right: 2px solid #b57ee0;
        box-shadow: 3px 0 20px rgba(181, 126, 224, 0.6);
      }

      .sidebar-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-right: 2rem;
      }

      .sidebar-title {
        color: #8a2be2;
        font-size: 1.1rem;
        margin-top: 0.5rem;
        font-family: "Overpass Mono", monospace;
        font-weight: bold;
        justify-content: center;
      }

      .sidebar-social {
        margin-top: 1rem;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem 1rem;
      }

      .sidebar-social a {
        font-size: 0.9rem;
        font-family: "Overpass Mono", monospace;
      }

      .sidebar-nav {
        padding: 0;
        margin: 0;
      }
      .sidebar-nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .sidebar-nav a {
        display: flex;
        padding: 1rem;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        color: #8a2be2;
        font-family: "Overpass Mono", monospace;
        font-size: calc(1.1rem + 3px);
        font-weight: 700;
        transition: background-color 0.2s ease-in-out;
        background-color: #eaedd4;
        margin-bottom: 1rem;
        border-radius: 5px 0 0 5px;
        border: 2px solid transparent;
        box-shadow: -2px 2px 4px rgba(0, 0, 0, 0.05), -2px -2px 4px rgba(0, 0, 0, 0.05);
      }
      .sidebar-nav a.active,
      .sidebar-nav a:hover {
        background-color: transparent;
        border-color: #b57ee0;
        border-right-color: transparent;
      }

      .sidebar-nav .material-icons,
      .main-content h2 .material-icons {
        background: linear-gradient(-45deg, #8a2be2, #972aeb, #ff7999, #9393ff);
        background-size: 400% 400%;
        animation: gradient-animation 10s ease infinite;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-size: 2.2rem; /* Match heading size */
      }

      .main-content {
        flex: 1;
        padding: 3rem;
        background-color: transparent;
        border-radius: 0;
        color: #8a2be2;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        margin: 0;
      }
      .hero-photo {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 5px solid #eaedd4;
        margin-bottom: 1rem;
        box-shadow: 0 0 20px #d4edda, 0 0 30px #eaedd4;
      }
      h1 {
        font-family: "Overpass Mono", monospace;
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      h2 {
        font-family: "Overpass Mono", monospace;
        font-size: 2rem;
        border-bottom: 2px solid #8a2be2;
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
        margin-top: 2rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }
      h3 {
        font-family: "Overpass Mono", monospace;
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
      }
      section {
        margin-bottom: 2rem;
        display: none; /* Hidden by default */
      }
      section.active {
        display: block; /* Shown when active */
      }
      .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 2rem;
      }
      .project-card {
        background: #f9fed1;
        padding: 1.5rem;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: transform 0.2s ease-in-out;
      }
      .project-card:hover {
        transform: scale(1.02);
      }
      .project-card .tech-stack span {
        color: #8a2be2;
        padding: 0.25rem 0.5rem;
        border-radius: 5px;
        font-size: 0.8rem;
        margin-right: 0.5rem;
        display: inline-block;
        margin-top: 0.5rem;
      }
      .project-card .tech-stack span:nth-child(4n + 1) {
        background: #e6e6fa; /* Pastel Purple */
      }
      .project-card .tech-stack span:nth-child(4n + 2) {
        background: #d4edda; /* Pastel Green */
      }
      .project-card .tech-stack span:nth-child(4n + 3) {
        background: #d1e7ff; /* Pastel Blue */
      }
      .project-card .tech-stack span:nth-child(4n + 4) {
        background: #ffd1dc; /* Pastel Pink */
      }
      .skill-list {
        list-style: disc;
        padding-left: 2rem;
        margin-top: 1rem;
      }
      .skill-list li {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
      }
      .skill-level-badge {
        text-transform: capitalize;
        padding: 0.25rem 0.75rem;
        border-radius: 4px;
        font-family: "Overpass Mono", monospace;
        font-size: 0.8rem;
        font-weight: 700;
        color: #8a2be2;
        flex-shrink: 0;
      }
      .skill-level-badge.expert { background-color: #d4edda; }
      .skill-level-badge.advanced { background-color: #d1e7ff; }
      .skill-level-badge.intermediate { background-color: #e6e6fa; }
      .skill-level-badge.beginner { background-color: #ffd1dc; }
      .card-list {
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }
      .info-card {
        background: #f9fed1;
        padding: 1.5rem;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: transform 0.2s ease-in-out;
      }
      .info-card:hover {
        transform: scale(1.02);
      }
      .language-card {
        background: #d4edda; /* Pastel Green */
      }
      .languages-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
      }
      .language-card .proficiency {
        text-transform: capitalize;
      }
      .language-card strong {
        font-family: "Overpass Mono", monospace;
        font-size: calc(1.1rem + 3px);
        font-weight: 700;
      }
      footer {
        text-align: center;
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid #e6e6fa;
        opacity: 0.8;
      }
    </style>
  </head>
  <body>
    <div class="page-wrapper">
      <aside class="sidebar">
        <div class="sidebar-header">
          <img class="hero-photo" src="https://i.sstatic.net/2fRi5z4Ml.png" alt="{{displayName}}" />
          <h1>{{displayName}}</h1>
          <h2 class="sidebar-title">Full Stack Developer</h2>
          <div class="sidebar-social">
            {{#email}}<a href="mailto:{{email}}">Email</a>{{/email}}
            {{#socialLinks}}<a href="{{url}}">{{label}}</a>{{/socialLinks}}
          </div>
        </div>
        <nav class="sidebar-nav">
          <ul>
            <li><a href="#about" data-target="about"><i class="material-icons">person</i>About Me</a></li>
            {{#has projects}}<li><a href="#projects" data-target="projects"><i class="material-icons">lightbulb</i>Projects</a></li>{{/has}}
            {{#has skills}}<li><a href="#skills" data-target="skills"><i class="material-icons">construction</i>Skills</a></li>{{/has}}
            {{#has experience}}<li><a href="#experience" data-target="experience"><i class="material-icons">business_center</i>Experience</a></li>{{/has}}
            {{#has education}}<li><a href="#education" data-target="education"><i class="material-icons">school</i>Education</a></li>{{/has}}
            {{#has languages}}<li><a href="#languages" data-target="languages"><i class="material-icons">language</i>Languages</a></li>{{/has}}
          </ul>
        </nav>
      </aside>

      <main class="main-content">
        <!-- About Section (from old header) -->
        <section id="about">
          <h2><i class="material-icons">person</i>About Me</h2>
          <p style="margin-top: 1rem; font-size: 22px;">A passionate developer with 8+ years of experience building products that serve millions of users. I care deeply about developer experience, performance, and clean architecture. When I'm not coding, you'll find me rock climbing or brewing specialty coffee.</p>
        </section>

        <!-- Projects -->
        {{#has projects}}
          <section id="projects">
            <h2><i class="material-icons">lightbulb</i>Projects</h2>
            <div class="projects-grid">
              {{#projects}}
                <article class="project-card">
                  <h3>{{name}}</h3>
                  {{#tagline}}<p style="opacity: 0.8; font-style: italic;">{{tagline}}</p>{{/tagline}}
                  {{#description}}<p style="margin-top: 0.5rem;">{{description}}</p>{{/description}}
                  {{#has techStack}}
                    <div class="tech-stack" style="margin-top: 1rem;">
                      {{#techStack}}<span>{{.}}</span>{{/techStack}}
                    </div>
                  {{/has}}
                  <div style="margin-top: 1rem;">
                    {{#liveUrl}}<a href="{{liveUrl}}">Live Demo</a>{{/liveUrl}}
                    {{#repoUrl}} | <a href="{{repoUrl}}" class="source-code-link">Source Code</a>{{/repoUrl}}
                  </div>
                </article>
              {{/projects}}
            </div>
          </section>
        {{/has}}

        <!-- Skills -->
        {{#has skills}}
          <section id="skills">
            <h2><i class="material-icons">construction</i>Skills</h2>
            <div class="projects-grid">
              {{#skills}}
                <article class="info-card">
                  <h3>{{category}}</h3>
                  <ul class="skill-list">
                    {{#items}}
                      <li><span>{{name}}</span> <span class="skill-level-badge {{lowercase level}}">{{level}}</span></li>
                    {{/items}}
                  </ul>
                </article>
              {{/skills}}
            </div>
          </section>
        {{/has}}

        <!-- Experience -->
        {{#has experience}}
          <section id="experience">
            <h2><i class="material-icons">business_center</i>Experience</h2>
            <div class="card-list">
              {{#experience}}
                <article class="info-card">
                  <h3>{{role}} at {{company}}</h3>
                  <p style="opacity: 0.8; font-style: italic;">{{fmtDate startDate}} – {{fmtDate endDate}}</p>
                  {{#description}}<p style="margin-top: 0.5rem;">{{description}}</p>{{/description}}
                  {{#has highlights}}
                    <ul style="margin-top: 1rem; padding-left: 1.5rem;">
                      {{#highlights}}<li>{{.}}</li>{{/highlights}}
                    </ul>
                  {{/has}}
                </article>
              {{/experience}}
            </div>
          </section>
        {{/has}}

        <!-- Education -->
        {{#has education}}
          <section id="education">
            <h2><i class="material-icons">school</i>Education</h2>
            <div class="card-list">
              {{#education}}
                <article class="info-card">
                  <h3>{{degree}}{{#if field}} in {{field}}{{/if}}</h3>
                  <p>{{institution}}</p>
                  <p style="opacity: 0.8; font-style: italic;">{{fmtDate startDate}} – {{fmtDate endDate}}</p>
                </article>
              {{/education}}
            </div>
          </section>
        {{/has}}

        <!-- Languages -->
        {{#has languages}}
          <section id="languages">
            <h2><i class="material-icons">language</i>Languages</h2>
            <div class="languages-grid">
              {{#languages}}<div class="info-card language-card"><strong>{{language}}</strong> - <span class="proficiency">{{proficiency}}</span></div>{{/languages}}
            </div>
          </section>
        {{/has}}
      </main>
    </div>

    <footer>
      <p>Built with <a href="{{toolsUrl}}">One File Tools</a></p>
    </footer>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const navLinks = document.querySelectorAll(".sidebar-nav a");
        const sections = document.querySelectorAll(".main-content section");
        const sidebarNav = document.querySelector(".sidebar-nav");

        let activeSectionId = "about";

        const showSection = (id) => {
          sections.forEach((section) => {
            section.classList.remove("active");
            if (section.id === id) {
              section.classList.add("active");
            }
          });
        };

        const setActiveLink = (id) => {
          navLinks.forEach((link) => {
            link.classList.remove("active");
            if (link.dataset.target === id) {
              link.classList.add("active");
            }
          });
        };

        // Initial setup
        showSection(activeSectionId);
        setActiveLink(activeSectionId);

        navLinks.forEach((link) => {
          // Click to set the active section
          link.addEventListener("click", (e) => {
            e.preventDefault();
            activeSectionId = link.dataset.target;
            showSection(activeSectionId);
            setActiveLink(activeSectionId);
          });

          // Hover to preview
          link.addEventListener("mouseover", () => {
            showSection(link.dataset.target);
          });
        });

        // When mouse leaves the nav area, revert to the active section
        sidebarNav.addEventListener("mouseleave", () => {
          showSection(activeSectionId);
        });
      });
    </script>
  </body>
</html>